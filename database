

CREATE DATABASE IF NOT EXISTS SkillMartDB;
USE SkillMartDB;


DROP TABLE IF EXISTS UserStorefronts;
DROP TABLE IF EXISTS MarketRates;


CREATE TABLE MarketRates (
    id INT AUTO_INCREMENT PRIMARY KEY,
    skill_name VARCHAR(100) UNIQUE,
    avg_price VARCHAR(50),
    demand_level VARCHAR(50)
);

CREATE TABLE UserStorefronts (
    id INT AUTO_INCREMENT PRIMARY KEY,
    user_name VARCHAR(100),
    detected_skill VARCHAR(100),
    confidence FLOAT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

